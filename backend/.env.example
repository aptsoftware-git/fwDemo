# LLM Configuration
LLM_MODE=local
# Options: local (Ollama) or claude (Anthropic)

# Local LLM (Ollama) Configuration
OLLAMA_URL=http://localhost:11434/api/chat
LLM_MODEL=qwen2.5:3b
LLM_TIMEOUT=35
# Timeout in seconds for LLM requests (default: 35)
LLM_MAX_WORKERS=4
# Maximum concurrent workers for parallel processing (default: 4)
LLM_MAX_TEXT_LENGTH=1800
# Maximum text length for context window (default: 1800)

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/frs_db
# Format: postgresql://username:password@host:port/database_name

# API Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Comma-separated list of allowed origins

# Data Directory (optional - defaults to relative path)
DATA_DIR=../data

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
